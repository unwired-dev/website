  },
  "devDependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@next/mdx": "^16.2.7",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@unwired/typescript-config": "workspace:*",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "tailwindcss": "^4",
    "typescript": "^5"
