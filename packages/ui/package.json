{
  "name": "@unwired/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./lib/*": "./src/lib/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts"
  },
  "scripts": {
    "format": "oxfmt --ignore-path ../../.gitignore --check .",
    "format:fix": "oxfmt --ignore-path ../../.gitignore --write .",
    "lint": "oxlint --type-aware --type-check --deny-warnings --report-unused-disable-directives",
    "lint:fix": "oxlint --type-aware --type-check --deny-warnings --report-unused-disable-directives --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "clsx": "^2.1.1",
    "tailwind-variants": "^3.2.2",
    "lucide-react": "^0.511.0",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/react": "^19",
    "@unwired/typescript-config": "workspace:*",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "react": "19.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
